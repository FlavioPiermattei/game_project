<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.control.Button?>

<?import javafx.scene.layout.BorderPane?>
<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="it.unicam.cs.mpgc.rpg129853.controller.GameController">

    <center>
    <VBox xmlns:fx="http://javafx.com/fxml"
      alignment="CENTER"
      spacing="20">

        <Label fx:id="gameStatusLabel" text="Game status"/>
    <Button fx:id="battleSceneButton" text="Battle Scene" onAction="#handleBattleScene"/>
    <Button fx:id="saveGameButton" text="Save Game" onAction="#handleSaveGame"/>
</VBox>

    </center>
</BorderPane>