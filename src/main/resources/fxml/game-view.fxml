<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ProgressBar?>
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="it.unicam.gioco.controller.GameController"
      alignment="CENTER"
      spacing="20">

    <Label text="Game Screen" style="-fx-font-size: 24px;"/>
    <Label fx:id="gameStatusLabel" text="Game status"/>
    <Label fx:id="sceneNameLabel" text="Scene name"/>
    <Label fx:id="playerNameLabel" text="Player Name"/>
    <Label fx:id="playerHealthLabel" text="Player Health"/>
    <ProgressBar fx:id="playerHealthBar" prefWidth="200"/>
    <Label fx:id="playerLevelLabel" text="Player Level"/>
    <Label fx:id="enemyNameLabel" text="Enemy Name"/>
    <Label fx:id="enemyHealthLabel" text="Enemy Health"/>
    <ProgressBar fx:id="enemyHealthBar" prefWidth="200"/>
    <Label fx:id="battleMessageLabel" text="Battle Message"/>
    <Button fx:id="attackButton" text="Attack" onAction="#handleAttack"/>
    <Button fx:id="healButton" text="Heal" onAction="#handleHeal"/>

</VBox>