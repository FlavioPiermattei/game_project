<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<!-- Root layout of the UI.
     BorderPane is a container that divides the screen into regions (top, center, bottom, etc.) -->
<BorderPane fx:id="rootPane"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="it.unicam.cs.mpgc.rpg129853.controller.MainController">

    <!-- Center region of the BorderPane -->
    <center>
        <!-- VBox arranges elements vertically (one under the other) -->
        <VBox fx:id="mainContainer" alignment="CENTER" spacing="20">

            <!-- Static title label -->
            <Label text="Benvenuto nel gioco" styleClass="title"/>

            <!-- Label controlled by the controller (dynamic content) -->
            <Label fx:id="statusLabel" text="Game not started"/>

            <!-- Button that triggers a method in the controller -->
            <Button text="Start Game" onAction="#handleStartGame" styleClass="menu-button"/>

            <!-- Loads a previously saved game, if any -->
            <Button text="Load Game" onAction="#handleLoadGame" styleClass="menu-button"/>

        </VBox>
    </center>

</BorderPane>